diff --git a/ui/base/ime/linux/input_method_auralinux.cc b/ui/base/ime/linux/input_method_auralinux.cc
index 64fabc7107..b734974e32 100644
--- a/ui/base/ime/linux/input_method_auralinux.cc
+++ b/ui/base/ime/linux/input_method_auralinux.cc
@@ -4,6 +4,8 @@
 
 #include "ui/base/ime/linux/input_method_auralinux.h"
 
+#include <locale.h>
+
 #include "base/auto_reset.h"
 #include "base/environment.h"
 #include "base/functional/bind.h"
@@ -52,10 +54,108 @@ InputMethodAuraLinux::InputMethodAuraLinux(
       is_sync_mode_(false),
       composition_changed_(false) {
   context_ = CreateLinuxInputMethodContext(this);
+
+  xkb_context* ctx = xkb_context_new(XKB_CONTEXT_NO_FLAGS);
+  if (ctx) {
+    const char* locale = setlocale(LC_CTYPE, nullptr);
+    if (!locale)
+      locale = "C";
+    xkb_compose_table_.reset(xkb_compose_table_new_from_locale(
+        ctx, locale, XKB_COMPOSE_COMPILE_NO_FLAGS));
+    if (xkb_compose_table_) {
+      xkb_compose_state_.reset(xkb_compose_state_new(
+          xkb_compose_table_.get(), XKB_COMPOSE_STATE_NO_FLAGS));
+    }
+    xkb_context_unref(ctx);
+  }
 }
 
 InputMethodAuraLinux::~InputMethodAuraLinux() = default;
 
+// Maps DomKey dead-key combining characters to XKB dead-key keysyms.
+// xkb_utf32_to_keysym() returns 0x01000000|cp for combining characters,
+// but compose tables use XKB_KEY_dead_* keysyms.
+static const struct {
+  uint32_t combining;
+  xkb_keysym_t dead_keysym;
+} kDeadKeyMap[] = {
+    {0x0300, XKB_KEY_dead_grave},
+    {0x0301, XKB_KEY_dead_acute},
+    {0x0302, XKB_KEY_dead_circumflex},
+    {0x0303, XKB_KEY_dead_tilde},
+    {0x0304, XKB_KEY_dead_macron},
+    {0x0306, XKB_KEY_dead_breve},
+    {0x0307, XKB_KEY_dead_abovedot},
+    {0x0308, XKB_KEY_dead_diaeresis},
+    {0x030A, XKB_KEY_dead_abovering},
+    {0x030B, XKB_KEY_dead_doubleacute},
+    {0x030C, XKB_KEY_dead_caron},
+    {0x030F, XKB_KEY_dead_doublegrave},
+    {0x0309, XKB_KEY_dead_hook},
+    {0x0311, XKB_KEY_dead_invertedbreve},
+    {0x0313, XKB_KEY_dead_abovecomma},
+    {0x0314, XKB_KEY_dead_abovereversedcomma},
+    {0x031B, XKB_KEY_dead_horn},
+    {0x0323, XKB_KEY_dead_belowdot},
+    {0x0324, XKB_KEY_dead_belowdiaeresis},
+    {0x0325, XKB_KEY_dead_belowring},
+    {0x0326, XKB_KEY_dead_belowcomma},
+    {0x0327, XKB_KEY_dead_cedilla},
+    {0x0328, XKB_KEY_dead_ogonek},
+    {0x032D, XKB_KEY_dead_belowcircumflex},
+    {0x032E, XKB_KEY_dead_belowbreve},
+    {0x0330, XKB_KEY_dead_belowtilde},
+    {0x0331, XKB_KEY_dead_belowmacron},
+    {0x0338, XKB_KEY_dead_stroke},
+    {0x0345, XKB_KEY_dead_iota},
+    {0x3099, XKB_KEY_dead_voiced_sound},
+    {0x309A, XKB_KEY_dead_semivoiced_sound},
+};
+
+bool InputMethodAuraLinux::MaybeFeedComposeSequence(
+    const ui::KeyEvent& event) {
+  if (!xkb_compose_state_)
+    return false;
+
+  xkb_keysym_t keysym = XKB_KEY_NoSymbol;
+  const DomKey dom_key = event.GetDomKey();
+  if (dom_key.IsComposeKey()) {
+    keysym = XKB_KEY_Multi_key;
+  } else if (dom_key.IsCharacter()) {
+    keysym = xkb_utf32_to_keysym(dom_key.ToCharacter());
+  } else if (dom_key.IsDeadKey()) {
+    const uint32_t combining = dom_key.ToDeadKeyCombiningCharacter();
+    for (const auto& entry : kDeadKeyMap) {
+      if (entry.combining == combining) {
+        keysym = entry.dead_keysym;
+        break;
+      }
+    }
+  }
+
+  if (keysym == XKB_KEY_NoSymbol)
+    return false;
+
+  xkb_compose_state_feed(xkb_compose_state_.get(), keysym);
+  switch (xkb_compose_state_get_status(xkb_compose_state_.get())) {
+    case XKB_COMPOSE_COMPOSING:
+      return true;
+    case XKB_COMPOSE_COMPOSED: {
+      char buf[64];
+      xkb_compose_state_get_utf8(xkb_compose_state_.get(), buf, sizeof(buf));
+      xkb_compose_state_reset(xkb_compose_state_.get());
+      OnCommit(base::UTF8ToUTF16(std::string_view(buf)));
+      return true;
+    }
+    case XKB_COMPOSE_CANCELLED:
+      xkb_compose_state_reset(xkb_compose_state_.get());
+      return false;
+    case XKB_COMPOSE_NOTHING:
+      return false;
+  }
+  return false;
+}
+
 LinuxInputMethodContext* InputMethodAuraLinux::GetContextForTesting() {
   return context_.get();
 }
@@ -141,6 +241,9 @@ ui::EventDispatchDetails InputMethodAuraLinux::DispatchKeyEvent(
     result_text_ = std::nullopt;
     base::AutoReset<bool> flipper(&is_sync_mode_, true);
     filtered = context_->DispatchKeyEvent(*event);
+
+    if (!filtered && event->type() == EventType::kKeyPressed)
+      filtered = MaybeFeedComposeSequence(*event);
   }
 
   // There are four cases here. They are a pair of two conditions:
@@ -434,6 +537,9 @@ void InputMethodAuraLinux::ResetContext() {
 
   context_->Reset();
 
+  if (xkb_compose_state_)
+    xkb_compose_state_reset(xkb_compose_state_.get());  
+
   composition_ = CompositionText();
   result_text_ = std::nullopt;
   is_sync_mode_ = false;
