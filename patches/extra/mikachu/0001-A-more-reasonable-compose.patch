 namespace ui {
 
@@ -23,6 +24,14 @@ struct XkbKeymapDeleter {
   void operator()(xkb_keymap* keymap) { xkb_keymap_unref(keymap); }
 };
 
+struct XkbComposeTableDeleter {
+  void operator()(xkb_compose_table* t) { xkb_compose_table_unref(t); }
+};
+
+struct XkbComposeStateDeleter {
+  void operator()(xkb_compose_state* s) { xkb_compose_state_unref(s); }
+};
+
 }  // namespace ui
 
 #endif  // UI_EVENTS_KEYCODES_SCOPED_XKB_H_
