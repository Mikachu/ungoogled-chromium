index 1418802862..4013fb02e6 100644
--- a/ui/base/ime/linux/input_method_auralinux.h
+++ b/ui/base/ime/linux/input_method_auralinux.h
@@ -12,6 +12,7 @@
 #include "ui/base/ime/composition_text.h"
 #include "ui/base/ime/input_method_base.h"
 #include "ui/base/ime/linux/linux_input_method_context.h"
+#include "ui/events/keycodes/scoped_xkb.h"
 #include "ui/gfx/native_ui_types.h"
 
 namespace ui {
@@ -88,6 +89,7 @@ class COMPONENT_EXPORT(UI_BASE_IME_LINUX) InputMethodAuraLinux
   void UpdateContextFocusState();
   void ResetContext();
   bool IgnoringNonKeyInput() const;
+  bool MaybeFeedComposeSequence(const ui::KeyEvent& event);
 
   const gfx::AcceleratedWidget widget_;
 
@@ -122,6 +124,11 @@ class COMPONENT_EXPORT(UI_BASE_IME_LINUX) InputMethodAuraLinux
   // the future.
   base::TimeTicks suppress_non_key_input_until_ = base::TimeTicks::UnixEpoch();
 
+  // XKB compose state for handling XCompose sequences when the platform IME
+  // context does not handle them (e.g. non-GTK Ozone/X11).
+  std::unique_ptr<xkb_compose_table, XkbComposeTableDeleter> xkb_compose_table_;
+  std::unique_ptr<xkb_compose_state, XkbComposeStateDeleter> xkb_compose_state_;
+
   // Used for making callbacks.
   base::WeakPtrFactory<InputMethodAuraLinux> weak_ptr_factory_{this};
 };
diff --git a/ui/events/keycodes/scoped_xkb.h b/ui/events/keycodes/scoped_xkb.h
index 66ab261359..e35a9fbeed 100644
--- a/ui/events/keycodes/scoped_xkb.h
+++ b/ui/events/keycodes/scoped_xkb.h
@@ -6,6 +6,7 @@
 #define UI_EVENTS_KEYCODES_SCOPED_XKB_H_
 
 #include <xkbcommon/xkbcommon.h>
