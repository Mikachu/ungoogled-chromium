 #include "ui/views/cascading_property.h"
@@ -257,6 +259,23 @@ void OmniboxPopupViewViews::WidgetObserverHelper::OnWidgetDestroying(
   popup_view_->OnWidgetDestroying(widget);
 }
 
+OmniboxPopupViewViews::HoverTracker::HoverTracker(
+    OmniboxPopupViewViews* popup)
+    : popup_(popup) {}
+
+OmniboxPopupViewViews::HoverTracker::~HoverTracker() = default;
+
+void OmniboxPopupViewViews::HoverTracker::OnMouseEvent(
+    ui::MouseEvent* event) {
+  if (event->type() == ui::EventType::kMouseMoved ||
+      event->type() == ui::EventType::kMouseEntered) {
+    gfx::Point point = event->location();
+    views::View::ConvertPointToTarget(
+        static_cast<views::View*>(event->target()), popup_, &point);
+    popup_->UpdateHoveredRow(popup_->GetIndexForPoint(point));
+  }
+}
+
 OmniboxPopupViewViews::OmniboxPopupViewViews(OmniboxViewViews* omnibox_view,
                                              OmniboxController* controller,
                                              LocationBarView* location_bar_view)
@@ -277,6 +296,11 @@ OmniboxPopupViewViews::OmniboxPopupViewViews(OmniboxViewViews* omnibox_view,
   SetLayoutManager(std::make_unique<views::BoxLayout>(
       views::BoxLayout::Orientation::kVertical));
 
+  // Receive exit events when the cursor leaves the popup entirely,
+  // not when it moves between child views.
+  SetNotifyEnterExitOnChild(true);
+  AddPreTargetHandler(&hover_tracker_);
+
   GetViewAccessibility().SetRole(ax::mojom::Role::kListBox);
   UpdateAccessibleStates();
   UpdateAccessibleControlIds();
@@ -284,6 +308,7 @@ OmniboxPopupViewViews::OmniboxPopupViewViews(OmniboxViewViews* omnibox_view,
 }
 
 OmniboxPopupViewViews::~OmniboxPopupViewViews() {
+  RemovePreTargetHandler(&hover_tracker_);
   // We don't need to close or delete `widget_` here. The OS either has already
   // closed the window, in which case it's been deleted, or it will soon.
   if (widget_) {
@@ -294,6 +319,25 @@ OmniboxPopupViewViews::~OmniboxPopupViewViews() {
   UpdateAccessibleControlIds();
 }
 
+void OmniboxPopupViewViews::OnMouseExited(const ui::MouseEvent& event) {
+  UpdateHoveredRow(OmniboxPopupSelection::kNoMatch);
+}
+
+void OmniboxPopupViewViews::UpdateHoveredRow(size_t new_index) {
+  if (hovered_index_ == new_index) {
+    return;
+  }
+  if (hovered_index_ != OmniboxPopupSelection::kNoMatch &&
+      HasMatchAt(hovered_index_)) {
+    result_view_at(hovered_index_)->SetHovered(false);
+  }
+  hovered_index_ = new_index;
+  if (hovered_index_ != OmniboxPopupSelection::kNoMatch &&
+      HasMatchAt(hovered_index_)) {
+    result_view_at(hovered_index_)->SetHovered(true);
+  }
+}
