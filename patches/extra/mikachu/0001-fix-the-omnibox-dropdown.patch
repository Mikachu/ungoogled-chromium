     const AutocompleteMatch& match,
     SkColor vector_icon_color) const {
@@ -355,6 +399,7 @@ void OmniboxPopupViewViews::UpdatePopupAppearance() {
 
   if (!should_be_open) {
     if (was_open) {
+      UpdateHoveredRow(OmniboxPopupSelection::kNoMatch);
       // Check whether omnibox should not close per UI DevTools settings.
       if (!widget_->ShouldHandleNativeWidgetActivationChanged(false)) {
         return;
