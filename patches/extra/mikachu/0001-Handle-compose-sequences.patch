   if (dom_code == DomCode::NONE)
@@ -823,6 +834,38 @@ bool XkbKeyboardLayoutEngine::Lookup(DomCode dom_code,
   }
 #endif  // BUILDFLAG(IS_CHROMEOS)
 
+  // Feed compose state machine on key press, when no non-shift modifiers
+  // are held (Ctrl+C etc. should not advance compose sequences).
+  const int kNonShiftlikeModifiers =
+      EF_CONTROL_DOWN | EF_ALT_DOWN | EF_COMMAND_DOWN;
+  if (is_key_press && xkb_compose_state_ &&
+      !(flags & kNonShiftlikeModifiers)) {
+    xkb_compose_state_feed(xkb_compose_state_.get(), xkb_keysym);
+    switch (xkb_compose_state_get_status(xkb_compose_state_.get())) {
+      case XKB_COMPOSE_COMPOSING:
+        // Mid-sequence: suppress the key from producing a character.
+        *dom_key = DomKey::UNIDENTIFIED;
+        *key_code = DomCodeToUsLayoutNonLocatedKeyboardCode(dom_code);
+        return true;
+      case XKB_COMPOSE_COMPOSED: {
+        char buf[64];
+        xkb_compose_state_get_utf8(xkb_compose_state_.get(), buf, sizeof(buf));
+        xkb_compose_state_reset(xkb_compose_state_.get());
+        pending_composed_text_ = base::UTF8ToUTF16(std::string_view(buf));
+        // Fall through to normal classification — dom_key/key_code will be
+        // overwritten below, but we return early here:
+        *dom_key = DomKey::UNIDENTIFIED;
+        *key_code = DomCodeToUsLayoutNonLocatedKeyboardCode(dom_code);
+        return true;
+      }
+      case XKB_COMPOSE_CANCELLED:
+        xkb_compose_state_reset(xkb_compose_state_.get());
+        break;
+      case XKB_COMPOSE_NOTHING:
+        break;
+    }
+  }
+
   // Classify the keysym and convert to DOM and VKEY representations.
   if (dom_code != DomCode::DIGIT2 || (flags & EF_CONTROL_DOWN) == 0) {
     // Non-character key. (We only support NUL as ^@ and ^2.)
@@ -844,8 +887,6 @@ bool XkbKeyboardLayoutEngine::Lookup(DomCode dom_code,
   // non-printable and a non-shiftlike modifier is down, we preferentially
   // return a printable key as if the modifier were not down.
   // https://w3c.github.io/uievents/#keys-guidelines
-  const int kNonShiftlikeModifiers =
-      EF_CONTROL_DOWN | EF_ALT_DOWN | EF_COMMAND_DOWN;
   if ((flags & kNonShiftlikeModifiers) && IsControlCharacter(character)) {
     int normal_ui_flags = flags & ~kNonShiftlikeModifiers;
     xkb_mod_mask_t normal_xkb_flags = EventFlagsToXkbFlags(normal_ui_flags);
@@ -872,6 +913,10 @@ bool XkbKeyboardLayoutEngine::Lookup(DomCode dom_code,
   return true;
 }
 
+std::u16string XkbKeyboardLayoutEngine::GetAndClearPendingComposedText() {
+  return std::exchange(pending_composed_text_, {});
+}
