diff --git a/ui/events/ozone/evdev/keyboard_evdev.cc b/ui/events/ozone/evdev/keyboard_evdev.cc
index be6ad811fe..f7883b4db4 100644
--- a/ui/events/ozone/evdev/keyboard_evdev.cc
+++ b/ui/events/ozone/evdev/keyboard_evdev.cc
@@ -193,7 +193,7 @@ void KeyboardEvdev::RefreshModifiers() {
       continue;
     DomKey dom_key;
     KeyboardCode keycode;
-    if (!keyboard_layout_engine_->Lookup(dom_code, EF_NONE, &dom_key, &keycode))
+    if (!keyboard_layout_engine_->Lookup(dom_code, EF_NONE, false, &dom_key, &keycode))
       continue;
     int flag = ModifierDomKeyToEventFlag(dom_key);
     if (flag == EF_NONE)
@@ -223,14 +223,28 @@ void KeyboardEvdev::DispatchKey(unsigned int key,
       return;
     }
     int modifier_flags = modifiers_->GetModifierFlags();
-    if (!keyboard_layout_engine_->Lookup(dom_code, modifier_flags, &dom_key,
-                                         &key_code)) {
+    if (!keyboard_layout_engine_->Lookup(dom_code, modifier_flags, down,
+                                         &dom_key, &key_code)) {
       return;
     }
     if (!repeat) {
       int flag = ModifierDomKeyToEventFlag(dom_key);
       UpdateModifier(flag, down);
     }
+    std::u16string composed = keyboard_layout_engine_->GetAndClearPendingComposedText();
+    if (!composed.empty()) {
+      // Dispatch each codepoint as a synthetic key event, or use a
+      // TextInsertEvent if one exists. For now, dispatch one KeyEvent
+      // per UTF-16 code unit (handles BMP; surrogate pairs need extra care).
+      for (char16_t ch : composed) {
+        KeyEvent text_event(EventType::kKeyPressed,
+                            VKEY_PROCESSKEY, dom_code,
+                            EF_NONE,
+                            DomKey::FromCharacter(ch), timestamp);
+        callback_.Run(&text_event);
+      }
+      return;
+    }
   }
 
   KeyEvent event(
