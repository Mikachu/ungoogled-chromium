 ui/base/ime/mojom/text_edit_commands.mojom    |  1 +
 ui/base/ime/text_edit_commands.inc            |  1 +
 ui/views/controls/textfield/textfield.cc      | 17 +++++++++++++
 9 files changed, 65 insertions(+), 7 deletions(-)

diff --git a/chrome/browser/ui/accelerator_table.cc b/chrome/browser/ui/accelerator_table.cc
index 51837acdf5..c602f35bf8 100644
--- a/chrome/browser/ui/accelerator_table.cc
+++ b/chrome/browser/ui/accelerator_table.cc
@@ -278,7 +278,8 @@ const AcceleratorMapping kDevToolsAcceleratorMap[] = {
      IDC_DEV_TOOLS_CONSOLE},
     {ui::VKEY_C, ui::EF_SHIFT_DOWN | ui::EF_CONTROL_DOWN,
      IDC_DEV_TOOLS_INSPECT},
-    {ui::VKEY_U, ui::EF_CONTROL_DOWN, IDC_VIEW_SOURCE},
+    //collides with deletewholeline binding
+    //{ui::VKEY_U, ui::EF_CONTROL_DOWN, IDC_VIEW_SOURCE},
 #endif  // !BUILDFLAG(IS_MAC)
 };
 
@@ -317,8 +318,9 @@ std::vector<AcceleratorMapping> GetAcceleratorList() {
                          std::end(kDevToolsAcceleratorMap));
 
 #if BUILDFLAG(IS_WIN) || BUILDFLAG(IS_LINUX)
-    accelerators->emplace_back(AcceleratorMapping(
-        {ui::VKEY_N, ui::EF_SHIFT_DOWN | ui::EF_ALT_DOWN, IDC_NEW_SPLIT_TAB}));
+    //this just crashes the browser
+    //accelerators->emplace_back(AcceleratorMapping(
+    //    {ui::VKEY_N, ui::EF_SHIFT_DOWN | ui::EF_ALT_DOWN, IDC_NEW_SPLIT_TAB}));
 #elif BUILDFLAG(IS_CHROMEOS)
     accelerators->emplace_back(
         AcceleratorMapping({ui::VKEY_N, ui::EF_CONTROL_DOWN | ui::EF_ALT_DOWN,
diff --git a/content/browser/renderer_host/render_widget_host_view_aura.cc b/content/browser/renderer_host/render_widget_host_view_aura.cc
index 1dddae6e47..725effc4ee 100644
--- a/content/browser/renderer_host/render_widget_host_view_aura.cc
+++ b/content/browser/renderer_host/render_widget_host_view_aura.cc
@@ -3329,10 +3329,27 @@ void RenderWidgetHostViewAura::ForwardKeyboardEventWithLatencyInfo(
     return;
 
 #if BUILDFLAG(IS_LINUX)
-  auto* linux_ui = ui::LinuxUi::instance();
-  if (!event.skip_if_unhandled && linux_ui && event.os_event) {
-    const auto command = linux_ui->GetTextEditCommandForEvent(
-        *event.os_event, GetTextInputFlags());
+  if (!event.skip_if_unhandled) {
+    ui::TextEditCommand command = ui::TextEditCommand::INVALID_COMMAND;
+
+    auto* linux_ui = ui::LinuxUi::instance();
+    if (linux_ui && event.os_event) {
+      command = linux_ui->GetTextEditCommandForEvent(
+          *event.os_event, GetTextInputFlags());
+    }
+
+    // Hardcoded fallback: Ctrl+U deletes the whole line.
+    // This applies even when GTK is not initialized.
+    if (command == ui::TextEditCommand::INVALID_COMMAND &&
+        (event.GetType() == blink::WebInputEvent::Type::kRawKeyDown ||
+         event.GetType() == blink::WebInputEvent::Type::kKeyDown) &&
+        event.windows_key_code == ui::VKEY_U &&
+        (event.GetModifiers() & blink::WebInputEvent::kControlKey) &&
+        !(event.GetModifiers() & blink::WebInputEvent::kShiftKey) &&
+        !(event.GetModifiers() & blink::WebInputEvent::kAltKey)) {
+      command = ui::TextEditCommand::DELETE_WHOLE_LINE;
+    }
+
     if (command != ui::TextEditCommand::INVALID_COMMAND) {
       // Transform from ui/ types to content/ types.
       std::vector<blink::mojom::EditCommandPtr> commands;
diff --git a/third_party/blink/renderer/core/editing/commands/editing_command_type.h b/third_party/blink/renderer/core/editing/commands/editing_command_type.h
