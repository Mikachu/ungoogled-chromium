+++ b/ui/base/ime/mojom/text_edit_commands.mojom
@@ -9,6 +9,7 @@ module ui.mojom;
 enum TextEditCommand {
   kDeleteBackward,
   kDeleteForward,
+  kDeleteWholeLine,
   kDeleteToBeginningOfLine,
   kDeleteToBeginningOfParagraph,
   kDeleteToEndOfLine,
diff --git a/ui/base/ime/text_edit_commands.inc b/ui/base/ime/text_edit_commands.inc
index 2e05820feb..d2712856ba 100644
--- a/ui/base/ime/text_edit_commands.inc
+++ b/ui/base/ime/text_edit_commands.inc
@@ -10,6 +10,7 @@
 
 TEXT_EDIT_COMMAND(DELETE_BACKWARD, kDeleteBackward)
 TEXT_EDIT_COMMAND(DELETE_FORWARD, kDeleteForward)
+TEXT_EDIT_COMMAND(DELETE_WHOLE_LINE, kDeleteWholeLine)
 TEXT_EDIT_COMMAND(DELETE_TO_BEGINNING_OF_LINE, kDeleteToBeginningOfLine)
 TEXT_EDIT_COMMAND(DELETE_TO_BEGINNING_OF_PARAGRAPH, \
   kDeleteToBeginningOfParagraph)
diff --git a/ui/views/controls/textfield/textfield.cc b/ui/views/controls/textfield/textfield.cc
index e672ba29b4..1a7a4064a5 100644
--- a/ui/views/controls/textfield/textfield.cc
+++ b/ui/views/controls/textfield/textfield.cc
@@ -1019,6 +1019,11 @@ bool Textfield::SkipDefaultKeyEventProcessing(const ui::KeyEvent& event) {
       return true;
     }
   }
+  // Also skip accelerators for hardcoded Linux text edit commands.
+  auto cmd = GetCommandForKeyEvent(event);
+  if (cmd == ui::TextEditCommand::DELETE_WHOLE_LINE && IsTextEditCommandEnabled(cmd)) {
+    return true;
+  }
 #endif
 
   // Skip backspace accelerator handling; editable textfields handle this key.
@@ -2019,6 +2024,7 @@ bool Textfield::IsTextEditCommandEnabled(ui::TextEditCommand command) const {
   switch (command) {
     case ui::TextEditCommand::DELETE_BACKWARD:
     case ui::TextEditCommand::DELETE_FORWARD:
+    case ui::TextEditCommand::DELETE_WHOLE_LINE:
     case ui::TextEditCommand::DELETE_TO_BEGINNING_OF_LINE:
     case ui::TextEditCommand::DELETE_TO_BEGINNING_OF_PARAGRAPH:
     case ui::TextEditCommand::DELETE_TO_END_OF_LINE:
@@ -2282,6 +2288,9 @@ void Textfield::DoExecuteTextEditCommand(
         command = ui::TextEditCommand::DELETE_FORWARD;
       }
       break;
+    case ui::TextEditCommand::DELETE_WHOLE_LINE:
+      add_to_kill_buffer = text_input_type_ != ui::TEXT_INPUT_TYPE_PASSWORD;
+      break;
 
     // Handle async PASTE separately to avoid splitting On[Before]UserAction
     // across async boundaries.
@@ -2305,6 +2314,11 @@ void Textfield::DoExecuteTextEditCommand(
     case ui::TextEditCommand::DELETE_FORWARD:
       changed = cursor_changed = model_->Delete(add_to_kill_buffer);
       break;
+    case ui::TextEditCommand::DELETE_WHOLE_LINE:
+      model_->MoveCursor(gfx::LINE_BREAK, end, gfx::SELECTION_NONE);
+      model_->MoveCursor(gfx::LINE_BREAK, begin, gfx::SELECTION_RETAIN);
+      changed = cursor_changed = model_->Backspace(add_to_kill_buffer);
+      break;
     case ui::TextEditCommand::DELETE_TO_BEGINNING_OF_LINE:
       model_->MoveCursor(gfx::LINE_BREAK, begin, gfx::SELECTION_RETAIN);
       changed = cursor_changed = model_->Backspace(add_to_kill_buffer);
@@ -2576,6 +2590,9 @@ ui::TextEditCommand Textfield::GetCommandForKeyEvent(
     case ui::VKEY_V:
       return (control && !alt) ? ui::TextEditCommand::PASTE
                                : ui::TextEditCommand::INVALID_COMMAND;
+    case ui::VKEY_U:
+      return (control && !alt) ? ui::TextEditCommand::DELETE_WHOLE_LINE
+                               : ui::TextEditCommand::INVALID_COMMAND;
     case ui::VKEY_RIGHT:
       // Ignore alt+right, which may be a browser navigation shortcut.
       if (alt) {
