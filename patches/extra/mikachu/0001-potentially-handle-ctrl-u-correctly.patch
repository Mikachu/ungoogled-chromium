@@ -17,6 +17,8 @@ std::string TextEditCommandToString(ui::TextEditCommand command) {
       return "DeleteBackward";
     case TextEditCommand::DELETE_FORWARD:
       return "DeleteForward";
+    case TextEditCommand::DELETE_WHOLE_LINE:
+      return "DeleteWholeLine";
     case TextEditCommand::DELETE_TO_BEGINNING_OF_LINE:
       return "DeleteToBeginningOfLine";
     case TextEditCommand::DELETE_TO_BEGINNING_OF_PARAGRAPH:
diff --git a/ui/base/ime/mojom/text_edit_commands.mojom b/ui/base/ime/mojom/text_edit_commands.mojom
index 6ec4a2009b..f0e5c8533a 100644
